---
import Layout from "../layouts/Layout.astro";
const pageTitle = "Contact | dettmer.dev";
const description =
  "Get in touch with Fabian Dettmer. Compose a message that opens directly in your local mail client — no third-party form processor, no data collection.";
---

<Layout pageTitle={pageTitle} description={description}>
  <h1>contact</h1>
  <span class="badge">no backend · no tracking · just mail</span>

  <h2>direct mail</h2>
  <p>
    Old-school but reliable. Click the address that fits, your mail client takes over from there.
  </p>
  <ul class="contact__list">
    <li><strong>General</strong> — <a class="legal__link" href="mailto:admin@dettmer.dev">admin@dettmer.dev</a></li>
    <li><strong>Postmaster</strong> — <a class="legal__link" href="mailto:postmaster@dettmer.dev">postmaster@dettmer.dev</a></li>
    <li><strong>Abuse / Misuse</strong> — <a class="legal__link" href="mailto:abuse@dettmer.dev">abuse@dettmer.dev</a></li>
    <li><strong>Security</strong> — see <a class="legal__link" href="/.well-known/security.txt">security.txt</a></li>
  </ul>

  <h2>compose a message</h2>
  <p>
    Prefer a form? This one is special: nothing leaves your browser. The button below builds a
    <code>mailto:</code> link from your input and hands it to your local mail client. No server,
    no JavaScript framework, no third party — therefore no GDPR consent banner, no captcha, no
    data ever stored anywhere on this site.
  </p>

  <form id="composeForm" class="contact__form" novalidate>
    <label class="contact__label">
      <span>Your name <em>(optional)</em></span>
      <input type="text" name="name" autocomplete="name" maxlength="120" />
    </label>

    <label class="contact__label">
      <span>Your email <em>(so I can reply)</em></span>
      <input type="email" name="reply" autocomplete="email" maxlength="200" required />
    </label>

    <label class="contact__label">
      <span>Subject</span>
      <input type="text" name="subject" maxlength="160" required />
    </label>

    <label class="contact__label">
      <span>Message</span>
      <textarea name="body" rows="7" maxlength="4000" required></textarea>
    </label>

    <!-- Honeypot: hidden from humans, irresistible to bots -->
    <label class="contact__honeypot" aria-hidden="true">
      Website
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>

    <div class="contact__actions">
      <button type="submit" class="btn">Open in mail client</button>
    </div>
    <p id="composeStatus" class="contact__status" role="status" aria-live="polite"></p>
  </form>

  <p class="contact__note">
    <small>
      Why no real form? A static site can't process forms securely without handing your data to
      a third party. The mail server behind <code>mail.dettmer.dev</code> already does the job
      far better than any embedded form ever could.
    </small>
  </p>
</Layout>

<script is:inline>
  (function () {
    const form = document.getElementById("composeForm");
    const status = document.getElementById("composeStatus");
    if (!form || !status) return;

    const RECIPIENT = "admin@dettmer.dev";

    function isValidEmail(value) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value);
    }

    form.addEventListener("submit", function (event) {
      event.preventDefault();
      status.textContent = "";
      status.dataset.state = "";

      const data = new FormData(form);
      const honey = (data.get("website") || "").toString().trim();
      if (honey.length > 0) {
        status.textContent = "Message rejected.";
        status.dataset.state = "error";
        return;
      }

      const name = (data.get("name") || "").toString().trim();
      const reply = (data.get("reply") || "").toString().trim();
      const subject = (data.get("subject") || "").toString().trim();
      const body = (data.get("body") || "").toString().trim();

      if (!isValidEmail(reply)) {
        status.textContent = "Please enter a valid email address so I can reply.";
        status.dataset.state = "error";
        return;
      }
      if (subject.length === 0 || body.length === 0) {
        status.textContent = "Subject and message can't be empty.";
        status.dataset.state = "error";
        return;
      }

      const signature =
        "\n\n--\nSent via dettmer.dev/kontakt" +
        (name ? "\nFrom: " + name : "") +
        "\nReply-To: " + reply;
      const fullBody = body + signature;

      const url =
        "mailto:" +
        encodeURIComponent(RECIPIENT) +
        "?subject=" +
        encodeURIComponent(subject) +
        "&body=" +
        encodeURIComponent(fullBody);

      status.textContent = "Opening your mail client…";
      status.dataset.state = "ok";
      window.location.href = url;
    });
  })();
</script>

<style>
  .contact__list {
    text-indent: 0;
  }
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }
  .contact__label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-family: var(--body);
    font-size: 0.95rem;
  }
  .contact__label > span {
    opacity: 0.85;
  }
  .contact__label em {
    font-style: italic;
    opacity: 0.6;
    font-size: 0.85em;
  }
  .contact__label input,
  .contact__label textarea {
    font-family: var(--body);
    font-size: 1rem;
    padding: 0.5rem 0.65rem;
    border-radius: 6px;
    border: 1px solid rgba(120, 194, 173, 0.3);
    background: rgba(120, 194, 173, 0.06);
    color: inherit;
    resize: vertical;
  }
  .contact__label input:focus,
  .contact__label textarea:focus {
    outline: 2px solid var(--text-link);
    outline-offset: 1px;
  }
  .contact__honeypot {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .contact__actions {
    display: flex;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .contact__status {
    text-align: center;
    text-indent: 0;
    min-height: 1.4em;
    margin: 0;
    font-size: 0.95rem;
  }
  .contact__status[data-state="error"] {
    color: #f38ba8;
  }
  .contact__status[data-state="ok"] {
    color: var(--text-link);
  }
  .contact__note {
    margin-top: 2rem;
    text-indent: 0;
    opacity: 0.75;
    text-align: center;
  }
  .legal__link {
    color: var(--text-link);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  :global(html.light) .legal__link {
    color: var(--text-link-light);
  }
  :global(html.light) .contact__label input,
  :global(html.light) .contact__label textarea {
    background: rgba(55, 90, 127, 0.05);
    border-color: rgba(55, 90, 127, 0.25);
  }
  :global(html.light) .contact__status[data-state="ok"] {
    color: var(--text-link-light);
  }
</style>
