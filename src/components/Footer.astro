---
const year = new Date().getFullYear();
---

<footer>
  <div class="center">
    <ul class="footer">
      <li class="icon__btn">
        <a class="icon__link" href="https://github.com/inventory69" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profile"
          ><span class="git-icon">GitHub</span></a
        >
      </li>
      <li class="icon__btn">
        <a class="icon__link" href="mailto:admin@dettmer.dev" aria-label="Send Email"
          ><span class="mail-icon">Email</span></a
        >
      </li>
      <li class="icon__btn">
        <a class="icon__link" href="https://discord.gg/YQBbBmCD" target="_blank" rel="noopener noreferrer" aria-label="Discord Server"
          ><span class="discord-icon">Discord</span></a
        >
      </li>
    </ul>
    <small
      >© {year} · 🌌 <a
        href="https://github.com/ttomczak3/Milky-Way"
        target="_blank"
        rel="noopener noreferrer"
        class="footer__link">milky way</a
      > · built with astro · probably overengineered</small
    >
    <small class="footer__legal">
      <a href="/impressum/" class="footer__link footer__link--muted">Impressum</a>
      <span aria-hidden="true">·</span>
      <a href="/kontakt/" class="footer__link footer__link--muted">Kontakt</a>
    </small>
  </div>
</footer>

<style>
  .footer__legal {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.75rem;
    opacity: 0.55;
  }
  .footer__legal a {
    text-decoration: none;
  }
  .footer__legal a:hover {
    text-decoration: underline;
    opacity: 1;
  }
  .footer__legal span {
    margin: 0 0.35rem;
    opacity: 0.7;
  }
</style>
